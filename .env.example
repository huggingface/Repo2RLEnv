# Repo2RLEnv — environment variable template
#
# Copy this file to `.env` and fill in real values.
#   cp .env.example .env
#
# Load before running CLI commands, e.g.:
#   set -a && source .env && set +a
#   uv run repo2rlenv generate ...
#
# Every var here is OPTIONAL — you only need the keys for providers you
# actually use. The CLI auto-resolves credentials from these env vars; no
# flag is required when the var is set.


# --- LLM providers (used by the bootstrap agent + synthesized pipelines) ---

# Anthropic (Claude Sonnet / Opus / Haiku). Set when using `--llm anthropic/...`.
# Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI (GPT-5, GPT-4o, o-series). Set when using `--llm openai/...`.
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Hugging Face (Inference Providers — Together, Nscale, Scaleway, ...).
# Set when using `--llm huggingface/<repo>:<provider>`.
# Get a token: https://huggingface.co/settings/tokens
# (Also used by `repo2rlenv` for HF Hub dataset publish.)
HF_TOKEN=


# --- Sandbox / runtime providers (optional, used by Harbor at task-run time) ---

# E2B (alternate sandbox backend). Only needed if you run tasks via
# `harbor run -e e2b ...`. Default Local Docker runs need nothing here.
# Get a key: https://e2b.dev/dashboard
E2B_API_KEY=


# --- Release tooling (maintainers only) ---

# PyPI API token for publishing releases. Stored in GitHub repo secrets in CI;
# only needed locally if you're cutting a release by hand.
# Get a token: https://pypi.org/manage/account/token/
PYPI_TOKEN=


# --- GitHub auth (optional) ---
#
# Auth for cloning + the GitHub API is resolved in this order:
#   1. `gh auth token` (run `gh auth login` once, no env var needed)
#   2. $GITHUB_TOKEN below (uncomment + paste a PAT to override)
#   3. Anonymous (works for public repos; private repos fail)
#
# Most users should just `gh auth login` and skip this section.
#
# GITHUB_TOKEN=
